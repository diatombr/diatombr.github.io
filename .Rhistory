blogdown::new_site(theme = "opera7133/tella", sample = TRUE)
# Copia as configurações do Tailwind e NPM
file.copy("themes/tella/exampleSite/package.json", ".", overwrite = TRUE)
file.copy("themes/tella/exampleSite/tailwind.config.js", ".", overwrite = TRUE)
file.copy("themes/tella/exampleSite/postcss.config.js", ".", overwrite = TRUE)
file.copy("themes/tella/exampleSite/config.toml", "config.toml", overwrite = TRUE)
# Instala as dependências (certifique-se de que o Node.js está instalado)
system("npm install")
blogdown::serve_site()
blogdown::serve_site()
blogdown::stop_server()
blogdown::serve_site()
blogdown::stop_server()
blogdown::serve_site()
blogdown::stop_server()
blogdown::serve_site()
blogdown::stop_server()
blogdown::serve_site()
hugo --debug
